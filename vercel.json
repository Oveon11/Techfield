{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "pnpm build:vercel",
  "functions": {
    "api/[...path].ts": {
      "maxDuration": 10,
      "includeFiles": "dist/public/**"
    }
  },
  "rewrites": [
    {
      "source": "/((?!api/).*)",
      "destination": "/api/$1"
    }
  ]
}
